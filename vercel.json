{
  "version": 2,
  "builds": [
    {
      "src": "src/api.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.11"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/api.py"
    }
  ],
  "functions": {
    "src/api.py": {
      "runtime": "python3.11"
    }
  },
  "env": {
    "ANTHROPIC_API_KEY": "@anthropic_api_key"
  }
}